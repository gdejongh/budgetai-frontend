{
  "name": "budget-ai-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate-api": "openapi-generator-cli generate -i http://localhost:8080/v3/api-docs -g typescript-angular -o src/app/core/api",
    "deploy": "npm run build:backend && npm run deploy:backend && npm run build:frontend && npm run deploy:frontend",
    "build:backend": "cd ../budgetai && ./gradlew bootJar",
    "build:frontend": "ng build",
    "deploy:backend": "cd ../budgetai && eb deploy",
    "deploy:frontend": "npm run s3-sync && npm run invalidate",
    "s3-sync": "aws s3 sync ./dist/budgetAi-frontend/browser s3://budget-ai-frontend-prod --delete --cache-control 'max-age=31536000' && aws s3 cp ./dist/budgetAi-frontend/browser/index.html s3://budget-ai-frontend-prod/index.html --metadata-directive REPLACE --cache-control 'no-cache, no-store, must-revalidate'",
    "invalidate": "aws cloudfront create-invalidation --distribution-id E2E12XHUU72NVN --paths '/*'"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "canvas-confetti": "^1.9.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@openapitools/openapi-generator-cli": "^2.30.0",
    "@types/canvas-confetti": "^1.9.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
